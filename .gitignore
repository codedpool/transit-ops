# TransitOps repository hygiene
# Only the client/ (Next.js) and server/ (Express) application folders belong in this repo.
# Planning docs and the brief PDF stay local and must never be committed.

# --- Root: ignore everything except the two app packages, this file and the README ---
/*
!/.gitignore
!/README.md
!/client/
!/server/

# Belt-and-suspenders: keep local-only docs out no matter what
/plan.md
/*.pdf
/mockup/

# --- Ignored inside client/ and server/ ---
# Dependencies
node_modules/

# Environment / secrets (never commit a real .env; commit .env.example instead)
.env
.env.local
.env.*.local

# Build & cache output
.next/
out/
dist/
build/
coverage/
*.tsbuildinfo

# Logs & OS files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
