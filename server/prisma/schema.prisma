// TransitOps — Prisma schema (PostgreSQL, self-hosted)
// Data-access layer for the Node/Express server. Plain JS client (no TypeScript required).
//
// Design notes:
// - Statuses / roles / types are enums (clean, queryable) instead of free text.
// - Money uses Decimal(12,2); never Float for currency.
// - DB tables/columns are snake_case (via @map/@@map); the generated JS client stays camelCase.
// - Audit fields (created_at / updated_at + created_by) on important tables.
// - Master data (vehicle/driver/role) is protected with onDelete: Restrict; optional links use SetNull.
// - Cross-row rules (cargo_weight <= vehicle.max_load_capacity, positive amounts) live in the
//   service layer, since they depend on related rows and cannot be static DB CHECK constraints.
//
// Computed metrics are NOT stored — they are derived with grouped queries:
//   Operational Cost (per vehicle) = SUM(fuel_logs.cost) + SUM(maintenance_logs.cost) + SUM(expenses.amount)
//   Fuel Efficiency (per trip)     = (final_odometer - start_odometer) / fuel_consumed  (fallback: planned_distance)
//   Vehicle ROI                    = (SUM(revenue) - (SUM(maintenance) + SUM(fuel))) / acquisition_cost
//   Fleet Utilization              = vehicles ON_TRIP / total non-retired vehicles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum RoleName {
  FLEET_MANAGER
  DRIVER // trip-creating / dispatching user (distinct from the Driver profile entity)
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleType {
  TRUCK
  VAN
  MINI
  CAR
  BUS
  TRAILER
  PICKUP
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum ExpenseCategory {
  TOLL
  MAINTENANCE
  PARKING
  INSURANCE
  FINE
  OTHER
}

// ---------- Models ----------

model Role {
  id          Int      @id @default(autoincrement())
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  roleId       Int      @map("role_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role            Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  vehicleDocuments VehicleDocument[]

  @@index([roleId])
  @@map("users")
}

model Vehicle {
  id                 Int           @id @default(autoincrement())
  registrationNumber String        @unique @map("registration_number")
  nameOrModel        String        @map("name_or_model")
  type               VehicleType
  maxLoadCapacity    Float         @map("max_load_capacity") // kg
  odometer           Float         @default(0)
  acquisitionCost    Decimal       @default(0) @map("acquisition_cost") @db.Decimal(12, 2)
  status             VehicleStatus @default(AVAILABLE)
  region             String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  documents       VehicleDocument[]

  @@index([status])
  @@index([region])
  @@index([type])
  @@map("vehicles")
}

model Driver {
  id                Int          @id @default(autoincrement())
  name              String
  licenseNumber     String       @unique @map("license_number")
  licenseCategory   String       @map("license_category")
  licenseExpiryDate DateTime     @map("license_expiry_date") @db.Date
  contactNumber     String       @map("contact_number")
  safetyScore       Float        @default(100) @map("safety_score")
  status            DriverStatus @default(AVAILABLE)
  region            String?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  trips Trip[]

  @@index([status])
  @@index([region])
  @@index([licenseExpiryDate])
  @@map("drivers")
}

model Trip {
  id                 Int        @id @default(autoincrement())
  source             String
  destination        String
  vehicleId          Int        @map("vehicle_id")
  driverId           Int        @map("driver_id")
  cargoWeight        Float      @map("cargo_weight") // kg
  plannedDistance    Float      @map("planned_distance") // km
  status             TripStatus @default(DRAFT)
  dispatchTime       DateTime?  @map("dispatch_time")
  completionTime     DateTime?  @map("completion_time")
  startOdometer      Float?     @map("start_odometer") // captured at dispatch
  finalOdometer      Float?     @map("final_odometer") // captured at completion
  fuelConsumed       Float?     @map("fuel_consumed") // liters, at completion
  revenue            Decimal?   @db.Decimal(12, 2) // freight charge / fare for ROI & profitability
  cancellationReason String?    @map("cancellation_reason")
  createdById        Int?       @map("created_by_id")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver    Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  fuelLogs  FuelLog[]
  expenses  Expense[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@index([dispatchTime])
  @@map("trips")
}

model MaintenanceLog {
  id          Int               @id @default(autoincrement())
  vehicleId   Int               @map("vehicle_id")
  serviceType String            @map("service_type")
  issueNotes  String?           @map("issue_notes")
  status      MaintenanceStatus @default(OPEN)
  openedAt    DateTime          @default(now()) @map("opened_at")
  closedAt    DateTime?         @map("closed_at")
  cost        Decimal?          @db.Decimal(12, 2)
  remarks     String?
  createdById Int?              @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([status])
  @@map("maintenance_logs")
}

model VehicleDocument {
  id              Int       @id @default(autoincrement())
  vehicleId       Int       @map("vehicle_id")
  title           String
  docType         String    @map("doc_type")
  referenceNumber String?   @map("reference_number")
  fileUrl         String?   @map("file_url")
  expiryDate      DateTime? @map("expiry_date") @db.Date
  createdById     Int?      @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@map("vehicle_documents")
}

model FuelLog {
  id              Int      @id @default(autoincrement())
  vehicleId       Int      @map("vehicle_id")
  liters          Float
  cost            Decimal  @db.Decimal(12, 2)
  date            DateTime @db.Date
  odometerReading Float?   @map("odometer_reading")
  relatedTripId   Int?     @map("related_trip_id")
  createdById     Int?     @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  relatedTrip Trip?   @relation(fields: [relatedTripId], references: [id], onDelete: SetNull)
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([date])
  @@map("fuel_logs")
}

model Expense {
  id            Int             @id @default(autoincrement())
  vehicleId     Int             @map("vehicle_id")
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(12, 2)
  date          DateTime        @db.Date
  notes         String?
  relatedTripId Int?            @map("related_trip_id")
  createdById   Int?            @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  relatedTrip Trip?   @relation(fields: [relatedTripId], references: [id], onDelete: SetNull)
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([category])
  @@index([date])
  @@map("expenses")
}
