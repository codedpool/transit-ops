# Copy this file to server/.env and fill in your local values.
# Prisma AND the Express server read DATABASE_URL from server/.env.
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# NOTE: if your password has special characters, URL-encode them
#       (e.g. '@' -> '%40', ':' -> '%3A', '/' -> '%2F', '?' -> '%3F').
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/transitops?schema=public"

# Express server port
PORT=4000

# Runtime: development | production
NODE_ENV=development

# Auth — generate your own secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="CHANGE_ME_generate_a_long_random_string"
JWT_EXPIRES_IN=8h
COOKIE_MAX_AGE_MS=28800000

# CORS — Next.js client origin allowed to send credentialed requests
CLIENT_ORIGIN=http://localhost:3000
